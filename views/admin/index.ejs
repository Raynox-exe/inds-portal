<%- include('../partials/header') %>

<div style="display: grid; grid-template-columns: 250px 1fr; min-height: 80vh;">
    <!-- Sidebar -->
    <aside style="background: var(--primary-dark); color: white; padding: 40px 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.1);">
        <h2 style="color: var(--accent); margin-bottom: 40px; font-size: 1.6rem; text-align: center; font-weight: 800; letter-spacing: 1px;">Admin<br>Portal</h2>
        <nav style="display: flex; flex-direction: column; gap: 8px;">
            <a href="/admin" style="color: white; display: block; padding: 14px 20px; border-radius: 8px; background: rgba(255,255,255,0.1); text-decoration: none; font-weight: 600; transition: all 0.3s;" onmouseover="this.style.background='var(--primary)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">Submission Queue</a>
            <a href="/admin/journals" style="color: rgba(255,255,255,0.7); display: block; padding: 14px 20px; border-radius: 8px; text-decoration: none; font-weight: 500; transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'">Manage Journals</a>
            <a href="/auth/logout" style="color: #fca5a5; display: block; padding: 14px 20px; border-radius: 8px; background: rgba(153, 27, 27, 0.2); text-decoration: none; font-weight: 600; margin-top: 50px; transition: all 0.3s; text-align: center; border: 1px solid rgba(153, 27, 27, 0.5);" onmouseover="this.style.background='rgba(153, 27, 27, 0.8)'; this.style.color='white'" onmouseout="this.style.background='rgba(153, 27, 27, 0.2)'; this.style.color='#fca5a5'">Secure Logout</a>
        </nav>
    </aside>

    <!-- Main -->
    <main style="padding: 40px; background: #f3f4f6;">
        <header style="margin-bottom: 40px;">
            <h1>Administrator Dashboard</h1>
            <p style="opacity: 0.7;">Central control for the INDS Research Management System.</p>
        </header>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: #dcfce7; color: #166534; padding: 15px; border-radius: 6px; margin-bottom: 25px;">
                <%= success_msg %>
            </div>
        <% } %>

        <!-- Stats -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; margin-bottom: 40px;">
            <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary);"></div>
                <h4 style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Total Researchers</h4>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main);"><%= stats.totalResearchers %></div>
            </div>
            <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--accent);"></div>
                <h4 style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Total Submissions</h4>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main);"><%= stats.totalSubmissions %></div>
            </div>
            <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #10b981;"></div>
                <h4 style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Published Papers</h4>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main);"><%= stats.publishedPapers %></div>
            </div>
        </div>

        <!-- Queue Table -->
        <div style="background: white; padding: 35px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color);">
            <h3 style="color: var(--primary-dark); font-size: 1.4rem; margin-bottom: 25px;">Pending Submissions Requiring Action</h3>
            <% if (pending.length === 0) { %>
                <div style="text-align: center; padding: 60px 20px; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1;">
                    <p style="color: var(--text-muted); font-size: 1.1rem;">Relax! No pending submissions at the moment.</p>
                </div>
            <% } else { %>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="background: #f8fafc; border-bottom: 2px solid var(--border-color);">
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Researcher</th>
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Manuscript Title</th>
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Date Submitted</th>
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% pending.forEach(sub => { %>
                                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                                    <td style="padding: 20px 16px; font-weight: 600; color: var(--text-main); font-size: 1.05rem;"><%= sub.full_name %></td>
                                    <td style="padding: 20px 16px; color: var(--text-muted);"><%= sub.title %></td>
                                    <td style="padding: 20px 16px; color: var(--text-muted);"><%= new Date(sub.submitted_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
                                    <td style="padding: 20px 16px;">
                                        <a href="/admin/review/<%= sub.id %>" class="btn" style="padding: 8px 20px; font-size: 0.9rem; border-radius: 6px;">Review Submission</a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
