<%- include('partials/header') %>

<main class="article-page" style="background: #f8fafc; padding: 80px 0;">
    <div class="container">
        <nav style="margin-bottom: 30px; opacity: 0.7;">
            <a href="/digest" style="text-decoration: none; color: inherit;">Research Digest</a> / 
            <span>Vol <%= article.volume_no %>, Issue <%= article.issue_no %></span>
        </nav>

        <div style="background: white; padding: 60px; border-radius: 24px; box-shadow: 0 20px 50px rgba(0,0,0,0.05); max-width: 900px; margin: 0 auto;">
            <header style="margin-bottom: 40px; border-bottom: 2px solid #f1f5f9; padding-bottom: 30px;">
                <h1 style="font-size: 2.5rem; color: #0f172a; margin-bottom: 20px; line-height: 1.2;"><%= article.title %></h1>
                
                <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 25px;">
                    <div style="font-size: 1.1rem; color: #475569; font-style: italic;">
                        <%= article.authors %>
                    </div>
                </div>

                <div style="display: flex; flex-wrap: wrap; gap: 15px; align-items: center;">
                    <span style="background: #eff6ff; color: #3b82f6; padding: 6px 16px; border-radius: 30px; font-size: 0.85rem; font-weight: 600;">
                        Vol <%= article.volume_no %>, Issue <%= article.issue_no %> (<%= article.publication_year %>)
                    </span>
                    
                    <% if (article.doi) { %>
                        <div style="display: flex; align-items: center; background: #fdf2f8; color: #db2777; padding: 6px 16px; border-radius: 30px; font-size: 0.85rem; font-weight: 600;">
                            <i class="fas fa-fingerprint" style="margin-right: 8px;"></i>
                            DOI: <a href="https://doi.org/<%= article.doi %>" target="_blank" style="color: inherit; text-decoration: underline; margin-left: 5px;"><%= article.doi %></a>
                        </div>
                    <% } %>
                </div>
            </header>

            <section class="abstract-content" style="margin-bottom: 50px;">
                <h3 style="font-size: 1.4rem; color: #1e293b; margin-bottom: 20px;">Abstract</h3>
                <div style="line-height: 1.8; color: #334155; font-size: 1.1rem; text-align: justify;">
                    <%= article.abstract %>
                </div>
            </section>

            <footer style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 25px; border-radius: 16px;">
                <div>
                    <span style="display: block; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin-bottom: 5px;">Published Date</span>
                    <strong style="color: #1e293b;"><%= new Date(article.published_at || article.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                </div>
                
                <div style="display: flex; gap: 15px;">
                    <a href="/uploads/published/<%= article.file_path %>" target="_blank" class="btn" style="padding: 12px 30px; border-radius: 12px; display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-file-pdf"></i> View Full PDF
                    </a>
                </div>
            </footer>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
