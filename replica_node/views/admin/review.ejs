<%- include('../partials/header') %>

<div style="display: grid; grid-template-columns: 250px 1fr; min-height: 80vh;">
    <aside style="background: #061e3d; color: white; padding: 40px 20px;">
        <h2 style="color: var(--accent); margin-bottom: 30px; font-size: 1.5rem;">Admin Portal</h2>
        <nav>
            <a href="/admin" style="color: white; display: block; padding: 12px; border-radius: 4px; background: var(--primary); text-decoration: none; margin-bottom: 10px;">Submission Queue</a>
            <a href="/admin/journals" style="color: white; display: block; padding: 12px; border-radius: 4px; text-decoration: none; margin-bottom: 10px;">Manage Journals</a>
            <a href="/auth/logout" style="color: white; display: block; padding: 12px; border-radius: 4px; background: #991b1b; text-decoration: none; margin-top: 50px;">Logout</a>
        </nav>
    </aside>

    <main style="padding: 40px; background: #f3f4f6;">
        <div style="margin-bottom: 30px;">
            <a href="/admin" style="color: var(--primary-dark); font-weight: 600; text-decoration: none;">← Back to Queue</a>
        </div>

        <h1>Review Manuscript</h1>

        <div style="background: white; padding: 40px; border-radius: 8px; box-shadow: var(--shadow); border: 1px solid var(--border-color);">
            <div style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                <span style="font-weight: 700; color: var(--primary-dark); display: block; margin-bottom: 5px; text-transform: uppercase; font-size: 0.75rem;">Researcher</span>
                <p><%= sub.full_name %> (<%= sub.email %>)</p>
            </div>

            <div style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                <span style="font-weight: 700; color: var(--primary-dark); display: block; margin-bottom: 5px; text-transform: uppercase; font-size: 0.75rem;">Article Title</span>
                <h2 style="color: var(--primary-dark); margin: 0;"><%= sub.title %></h2>
            </div>

            <div style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                <span style="font-weight: 700; color: var(--primary-dark); display: block; margin-bottom: 5px; text-transform: uppercase; font-size: 0.75rem;">Author(s)</span>
                <p><%= sub.authors %></p>
            </div>

            <div style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                <span style="font-weight: 700; color: var(--primary-dark); display: block; margin-bottom: 5px; text-transform: uppercase; font-size: 0.75rem;">Abstract</span>
                <p style="white-space: pre-wrap;"><%= sub.abstract %></p>
            </div>

            <div style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                <span style="font-weight: 700; color: var(--primary-dark); display: block; margin-bottom: 5px; text-transform: uppercase; font-size: 0.75rem;">Manuscript File</span>
                <a href="/uploads/manuscripts/<%= sub.file_path %>" target="_blank" class="btn" style="background: var(--primary-dark); font-size: 0.85rem; padding: 8px 20px;">Download Original Manuscript</a>
            </div>

            <!-- Decisions -->
            <div style="margin-top: 50px; background: #f8fafc; padding: 30px; border-radius: 8px;">
                <h3>Submit Review Decision</h3>
                <form action="/admin/review/<%= sub.id %>" method="POST">
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Feedback to Researcher</label>
                        <textarea name="feedback" rows="4" style="width: 100%; padding: 12px; border: 1px solid var(--border-color); border-radius: 4px;" placeholder="Optional comments for the author..."></textarea>
                    </div>
                    
                    <div style="display: flex; gap: 15px;">
                        <button type="submit" name="action" value="accept" class="btn" style="background: #166534; flex: 1; border: none; cursor: pointer;">Accept Article</button>
                        <button type="submit" name="action" value="reject" class="btn" style="background: #991b1b; flex: 1; border: none; cursor: pointer;">Reject Article</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
