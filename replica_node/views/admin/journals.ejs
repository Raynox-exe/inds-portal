<%- include('../partials/header') %>

<div style="display: grid; grid-template-columns: 250px 1fr; min-height: 80vh;">
    <aside style="background: #061e3d; color: white; padding: 40px 20px;">
        <h2 style="color: var(--accent); margin-bottom: 30px; font-size: 1.5rem;">Admin Portal</h2>
        <nav>
            <a href="/admin" style="color: white; display: block; padding: 12px; border-radius: 4px; text-decoration: none; margin-bottom: 10px;">Submission Queue</a>
            <a href="/admin/journals" style="color: white; display: block; padding: 12px; border-radius: 4px; background: var(--primary); text-decoration: none; margin-bottom: 10px;">Manage Journals</a>
            <a href="/auth/logout" style="color: white; display: block; padding: 12px; border-radius: 4px; background: #991b1b; text-decoration: none; margin-top: 50px;">Logout</a>
        </nav>
    </aside>

    <main style="padding: 40px; background: #f3f4f6;">
        <h1>Journal Management</h1>
        <p style="opacity: 0.7; margin-bottom: 40px;">Control deployment and publication cycles.</p>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: #dcfce7; color: #166534; padding: 15px; border-radius: 6px; margin-bottom: 25px;">
                <%= success_msg %>
            </div>
        <% } %>

        <!-- Create Journal -->
        <div style="background: white; padding: 30px; border-radius: 8px; box-shadow: var(--shadow); margin-bottom: 30px;">
            <h3>Create New Volume/Issue</h3>
            <form action="/admin/journals/create" method="POST" style="display: flex; gap: 15px; margin-top: 20px;">
                <div style="flex: 1;">
                    <label style="display:block; font-size: 0.8rem; font-weight:600;">Volume No.</label>
                    <input type="number" name="volume" required style="width: 100%; padding: 10px; border: 1px solid #ddd;">
                </div>
                <div style="flex: 1;">
                    <label style="display:block; font-size: 0.8rem; font-weight:600;">Issue No.</label>
                    <input type="number" name="issue" required style="width: 100%; padding: 10px; border: 1px solid #ddd;">
                </div>
                <div style="flex: 1;">
                    <label style="display:block; font-size: 0.8rem; font-weight:600;">Reg. Year</label>
                    <input type="number" name="year" value="<%= new Date().getFullYear() %>" required style="width: 100%; padding: 10px; border: 1px solid #ddd;">
                </div>
                <button type="submit" class="btn" style="align-self: flex-end; padding: 10px 20px;">Create Draft</button>
            </form>
        </div>

        <!-- List -->
        <div style="background: white; padding: 30px; border-radius: 8px; box-shadow: var(--shadow);">
            <h3 style="margin-bottom: 25px;">Journal Status & Deployment</h3>
            <% if (journals.length === 0) { %>
                <p style="text-align: center; color: var(--text-muted);">No journals created yet.</p>
            <% } else { %>
                <% journals.forEach(j => { %>
                    <div style="border: 1px solid #eee; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <h4 style="margin: 0;">Volume <%= j.volume_no %>, Issue <%= j.issue_no %> (<%= j.publication_year %>)</h4>
                                <span style="padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; color: white; background: <%= j.status === 'published' ? '#166534' : '#6b7280' %>;">
                                    <%= j.status.toUpperCase() %>
                                </span>
                            </div>
                            <div>
                                <% if (j.status === 'draft') { %>
                                    <a href="/admin/journals/deploy/<%= j.id %>" class="btn" style="background: #c2410c; padding: 8px 15px; font-size: 0.85rem;">🚀 Deploy Publicly</a>
                                <% } else { %>
                                    <span style="color: #166534; font-weight: 700;">✅ LIVE ON WEB</span>
                                <% } %>
                            </div>
                        </div>

                        <!-- Assign Paper -->
                        <% if (j.status === 'draft' && readyToPublish.length > 0) { %>
                            <div style="margin-top: 20px; background: #fafafa; padding: 15px; border-radius: 6px;">
                                <form action="/admin/journals/assign" method="POST" style="display: flex; gap: 10px;">
                                    <input type="hidden" name="journal_id" value="<%= j.id %>">
                                    <select name="sub_id" required style="flex: 2; padding: 10px;">
                                        <option value="">Assign an accepted paper...</option>
                                        <% readyToPublish.forEach(ready => { %>
                                            <option value="<%= ready.id %>"><%= ready.title %></option>
                                        <% }); %>
                                    </select>
                                    <input type="text" name="pages" placeholder="Pages (e.g. 12-45)" style="flex: 1; padding: 10px;">
                                    <button type="submit" class="btn" style="background: var(--primary-dark); font-size: 0.8rem;">Assign</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
