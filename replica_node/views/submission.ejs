<%- include('partials/header') %>

<section class="page-header">
    <div class="container">
        <h1>Online Submission</h1>
        <p>Guidelines and portal access for scholarly contributions.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div style="max-width: 900px; margin: 0 auto;">
            <div style="background: var(--bg-soft); padding: clamp(20px, 5vw, 50px); border-radius: 15px; border-left: 6px solid var(--primary); margin-bottom: 50px;">
                <h2 style="color: var(--primary-dark); margin-bottom: 20px;">Call for Articles</h2>
                <p style="font-size: 1.1rem; line-height: 1.8;">The Institute for Niger Delta Studies welcomes manuscripts for its upcoming Research Digest volumes. Submissions must be original, peer-reviewed contributions addressing regional themes.</p>
                
                <div style="display: flex; gap: clamp(20px, 5vw, 40px); margin-top: 30px; flex-wrap: wrap;">
                    <div>
                        <span style="font-weight: 700; display: block; color: var(--primary);">DEADLINE</span>
                        <span>September 30th, 2024</span>
                    </div>
                    <div>
                        <span style="font-weight: 700; display: block; color: var(--primary);">PEER REVIEW</span>
                        <span>4-6 Weeks</span>
                    </div>
                </div>
            </div>

            <h3>Submission Guidelines</h3>
            <ul style="line-height: 2; margin-bottom: 40px; color: var(--text-main);">
                <li>Manuscripts should be between 4,000 to 7,000 words.</li>
                <li>Abstracts must not exceed 300 words.</li>
                <li>Authors should strictly follow the APA 7th Edition referencing style.</li>
                <li>All submissions must be in .DOC, .DOCX, or .PDF format.</li>
            </ul>

            <div style="text-align: center; background: white; padding: 40px; border: 2px dashed var(--border-color); border-radius: 12px;">
                <h4 style="margin-bottom: 20px;">Ready to submit your work?</h4>
                <% if (user) { %>
                    <a href="/dashboard/submit" class="btn">Go to Submission Portal</a>
                <% } else { %>
                    <p style="margin-bottom: 20px;">You must have a researcher account to submit manuscripts.</p>
                    <div style="display: flex; gap: 15px; justify-content: center;">
                        <a href="/auth/login" class="btn">Login</a>
                        <a href="/auth/register" class="btn btn-outline" style="background: transparent; color: var(--primary); border: 1px solid var(--primary);">Register</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
