<!-- views/programs.ejs -->
<%- include('partials/header') %>

<section class="page-header">
    <div class="container">
        <h1>Programs & Initiatives</h1>
        <p>Core academic and developmental programs driving regional progress.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="programs-grid responsive-grid">
            <div class="program-card" style="background: white; padding: 40px; border-radius: 12px; box-shadow: var(--shadow); border: 1px solid var(--border-color);">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">🎓</div>
                <h3>Research Digest</h3>
                <p>Our flagship peer-reviewed journal publishing original research across all disciplines related to the Niger Delta.</p>
                <a href="/digest" style="color: var(--primary); font-weight: 600; text-decoration: none; display: block; margin-top: 20px;">Browse Issues →</a>
            </div>
            
            <div class="program-card" style="background: white; padding: 40px; border-radius: 12px; box-shadow: var(--shadow); border: 1px solid var(--border-color);">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">🎤</div>
                <h3>Memorial Lectures</h3>
                <p>The Chief Melford Okilo Memorial Lecture series brings together thought leaders to discuss governance and development.</p>
                <a href="#" style="color: var(--primary); font-weight: 600; text-decoration: none; display: block; margin-top: 20px;">Learn More →</a>
            </div>

            <div class="program-card" style="background: white; padding: 40px; border-radius: 12px; box-shadow: var(--shadow); border: 1px solid var(--border-color);">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">📚</div>
                <h3>Regional Documentation</h3>
                <p>Archiving the history, folklore, and socio-economic data of the region's diverse ethnic groups.</p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>

