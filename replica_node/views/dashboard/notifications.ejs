<%- include('../partials/header') %>

<div style="display: grid; grid-template-columns: 250px 1fr; min-height: 80vh;">
    <!-- Sidebar -->
    <aside style="background: var(--primary-dark); color: white; padding: 40px 20px;">
        <h2 style="color: var(--accent); margin-bottom: 30px; font-size: 1.5rem;">Researcher Portal</h2>
        <nav>
            <a href="/dashboard" style="color: white; display: block; padding: 12px; border-radius: 4px; text-decoration: none; margin-bottom: 10px;">Overview</a>
            <a href="/dashboard/submit" style="color: white; display: block; padding: 12px; border-radius: 4px; text-decoration: none; margin-bottom: 10px;">Submit Manuscript</a>
            <a href="/dashboard/notifications" style="color: white; display: block; padding: 12px; border-radius: 4px; background: var(--primary); text-decoration: none; margin-bottom: 10px;">Notifications</a>
            <a href="/auth/logout" style="color: white; display: block; padding: 12px; border-radius: 4px; background: #991b1b; text-decoration: none; margin-top: 50px;">Logout</a>
        </nav>
    </aside>

    <!-- Main -->
    <main style="padding: 40px; background: #f9fafb;">
        <h1>Your Notifications</h1>
        <p style="opacity: 0.7; margin-bottom: 40px;">Stay up to date with your submission status.</p>

        <% if (notifications.length === 0) { %>
            <div style="text-align: center; padding: 80px; opacity: 0.5; background: white; border-radius: 8px; border: 1px solid var(--border-color);">
                <p>You don't have any notifications yet.</p>
            </div>
        <% } else { %>
            <% notifications.forEach(note => { %>
                <div style="background: white; padding: 20px; border-radius: 8px; box-shadow: var(--shadow); border: 1px solid var(--border-color); border-left: 5px solid <%= note.is_read ? '#ccc' : 'var(--primary)' %>; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <p style="<%= !note.is_read ? 'font-weight: 600;' : '' %> margin-bottom: 5px;"><%= note.message %></p>
                        <span style="font-size: 0.8rem; opacity: 0.6;"><%= new Date(note.created_at).toLocaleString() %></span>
                    </div>
                    <% if (!note.is_read) { %>
                        <a href="/dashboard/notifications/read/<%= note.id %>" class="btn" style="padding: 5px 12px; font-size: 0.75rem;">Mark as Read</a>
                    <% } %>
                </div>
            <% }); %>
        <% } %>
    </main>
</div>

<%- include('../partials/footer') %>
