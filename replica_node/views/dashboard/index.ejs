<%- include('../partials/header') %>

<div style="display: grid; grid-template-columns: 250px 1fr; min-height: 80vh;">
    <!-- Sidebar -->
    <aside style="background: var(--primary-dark); color: white; padding: 40px 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.1);">
        <h2 style="color: var(--accent); margin-bottom: 40px; font-size: 1.6rem; text-align: center; font-weight: 800; letter-spacing: 1px;">Researcher<br>Portal</h2>
        <nav style="display: flex; flex-direction: column; gap: 8px;">
            <a href="/dashboard" style="color: white; display: block; padding: 14px 20px; border-radius: 8px; background: rgba(255,255,255,0.1); text-decoration: none; font-weight: 600; transition: all 0.3s;" onmouseover="this.style.background='var(--primary)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">Overview</a>
            <a href="/dashboard/submit" style="color: rgba(255,255,255,0.7); display: block; padding: 14px 20px; border-radius: 8px; text-decoration: none; font-weight: 500; transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'">Submit Manuscript</a>
            <a href="/dashboard/notifications" style="color: rgba(255,255,255,0.7); display: block; padding: 14px 20px; border-radius: 8px; text-decoration: none; font-weight: 500; transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'" onmouseout="this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'">Notifications</a>
            <a href="/auth/logout" style="color: #fca5a5; display: block; padding: 14px 20px; border-radius: 8px; background: rgba(153, 27, 27, 0.2); text-decoration: none; font-weight: 600; margin-top: 50px; transition: all 0.3s; text-align: center; border: 1px solid rgba(153, 27, 27, 0.5);" onmouseover="this.style.background='rgba(153, 27, 27, 0.8)'; this.style.color='white'" onmouseout="this.style.background='rgba(153, 27, 27, 0.2)'; this.style.color='#fca5a5'">Secure Logout</a>
        </nav>
    </aside>

    <!-- Main -->
    <main style="padding: 40px; background: #f9fafb;">
        <header style="margin-bottom: 40px;">
            <h1>Welcome, <%= user.name %></h1>
            <p style="opacity: 0.7;">View and manage your academic submissions.</p>
        </header>

        <% if (success_msg && success_msg.length > 0) { %>
            <div style="background: #dcfce7; color: #166534; padding: 15px; border-radius: 6px; margin-bottom: 25px;">
                <%= success_msg %>
            </div>
        <% } %>

        <% if (unreadCount > 0) { %>
            <div style="background: #eff6ff; border-left: 4px solid var(--primary); padding: 20px; margin-bottom: 30px; border-radius: 4px;">
                <h4 style="margin-bottom: 5px; color: var(--primary-dark);">New Researcher Updates!</h4>
                <p style="font-size: 0.9rem;">You have <%= unreadCount %> unread notifications. <a href="/dashboard/notifications" style="font-weight: 600;">View details</a></p>
            </div>
        <% } %>

        <!-- Stats -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; margin-bottom: 40px;">
            <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary);"></div>
                <h4 style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Total Submissions</h4>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main);"><%= submissions.length %></div>
            </div>
            <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #10b981;"></div>
                <h4 style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Accepted</h4>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main);"><%= submissions.filter(s => s.status === 'accepted').length %></div>
            </div>
            <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #f59e0b;"></div>
                <h4 style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Pending Review</h4>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--text-main);"><%= submissions.filter(s => s.status === 'pending').length %></div>
            </div>
        </div>

        <!-- Submissions Table -->
        <div style="background: white; padding: 35px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border-color);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                <h3 style="color: var(--primary-dark); font-size: 1.4rem;">Your Recent Submissions</h3>
                <a href="/dashboard/submit" class="btn" style="padding: 8px 20px; font-size: 0.9rem;">+ New Submission</a>
            </div>
            
            <% if (submissions.length === 0) { %>
                <div style="text-align: center; padding: 60px 20px; background: #f8fafc; border-radius: 8px; border: 1px dashed #cbd5e1;">
                    <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 15px;">You haven't submitted any articles yet.</p>
                    <a href="/dashboard/submit" class="btn btn-outline" style="color: var(--primary); border-color: var(--primary);">Start your first submission</a>
                </div>
            <% } else { %>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="background: #f8fafc; border-bottom: 2px solid var(--border-color);">
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Manuscript Title</th>
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Date Submitted</th>
                                <th style="padding: 16px; color: var(--text-muted); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% submissions.forEach(sub => { %>
                                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                                    <td style="padding: 20px 16px; font-weight: 600; color: var(--text-main); font-size: 1.05rem;"><%= sub.title %></td>
                                    <td style="padding: 20px 16px; color: var(--text-muted);"><%= new Date(sub.submitted_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
                                    <td style="padding: 20px 16px;">
                                        <span style="padding: 6px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;" 
                                              class="status-<%= sub.status %>">
                                            <%= sub.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </main>
</div>

<style>
    .status-pending { background: #fef9c3; color: #854d0e; }
    .status-accepted { background: #dcfce7; color: #166534; }
    .status-rejected { background: #fee2e2; color: #991b1b; }
</style>

<%- include('../partials/footer') %>
