<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INDS | Institute for Niger Delta Studies</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<!-- views/partials/header.ejs -->
<header class="main-header">
    <div class="top-bar">
        <div class="container">
            <div class="contact-info">
                <span>📞 +234 (806 476 1059)</span> | 
                <span>📧 info@inds.org.ng</span>
            </div>
            <div class="social-links">
                <a href="#" style="color:white; margin-left:10px;">Fb</a>
                <a href="#" style="color:white; margin-left:10px;">Tw</a>
                <a href="#" style="color:white; margin-left:10px;">In</a>
            </div>
        </div>
    </div>
    
    <div class="header-content">
        <div class="container">
            <div class="logo">
                <a href="/">
                    <img src="/assets/img/logo.png" alt="INDS Logo">
                </a>
            </div>
            <nav class="main-nav">
                <ul>
                    <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a></li>
                    <li><a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About Us</a></li>
                    <li><a href="/digest" class="<%= currentPath === '/digest' ? 'active' : '' %>">Research Digest</a></li>
                    <li><a href="/programs" class="<%= currentPath === '/programs' ? 'active' : '' %>">Programs</a></li>
                    <li><a href="/submission" class="<%= currentPath === '/submission' ? 'active' : '' %>">Submission</a></li>
                    
                    <% if (user) { %>
                        <li><a href="<%= user.role === 'admin' ? '/admin' : '/dashboard' %>" class="btn" style="color:white; padding: 5px 15px; margin-top:-5px;">Dashboard</a></li>
                    <% } else { %>
                        <li><a href="/auth/login" class="btn <%= currentPath === '/auth/login' ? 'active' : '' %>" style="color:white; padding: 5px 15px; margin-top:-5px;">Login</a></li>
                        <li><a href="/auth/register" class="btn btn-outline <%= currentPath === '/auth/register' ? 'active' : '' %>" style="padding: 5px 15px; margin-top:-5px; margin-left: 10px;">Sign Up</a></li>
                    <% } %>
                </ul>
            </nav>
        </div>
    </div>
</header>
