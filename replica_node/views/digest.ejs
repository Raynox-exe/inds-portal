<%- include('partials/header') %>

    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Research Digest</h1>
            <p>Access the intellectual output of the Institute for Niger Delta Studies.</p>
        </div>
    </section>

    <!-- Digest List -->
    <section class="section">
        <div class="container">
            <div class="volume-selector" style="margin-bottom: 40px; background: var(--bg-soft); padding: 25px; border-radius: 15px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 20px;">
                <i class="fas fa-filter" style="color: var(--accent); font-size: 1.2rem;"></i>
                <form action="/digest" method="GET" style="display: flex; gap: 15px; flex-grow: 1;">
                    <span style="font-weight: 700; color: var(--primary); align-self: center;">Browse Issues:</span>
                    <select name="volume_issue" onchange="const val = this.value.split('|'); if(val.length==2){ window.location='/digest?volume='+val[0]+'&issue='+val[1]; }" style="padding: 12px 20px; border-radius: 10px; border: 1px solid var(--border-color); background: white; font-weight: 500; outline: none; min-width: 250px;">
                        <option value="">All Volumes / Issues</option>
                        <% allJournals.forEach(j => { %>
                            <option value="<%= j.volume_no %>|<%= j.issue_no %>" <%= (selectedVol == j.volume_no && selectedIssue == j.issue_no) ? 'selected' : '' %>>
                                Vol <%= j.volume_no %>, Issue <%= j.issue_no %> (<%= j.publication_year %>)
                            </option>
                        <% }); %>
                    </select>
                    <a href="/digest" class="btn btn-outline" style="padding: 10px 25px; font-size: 0.85rem; border-color: var(--primary); color: var(--primary);">Clear Filters</a>
                </form>
            </div>

            <div class="table-container" style="background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-md);">
                <% if (!articles || articles.length === 0) { %>
                    <div style="text-align: center; padding: 100px; opacity: 0.5;">
                        <i class="fas fa-folder-open" style="font-size: 4rem; margin-bottom: 20px;"></i>
                        <p>No published articles found for this selection.</p>
                    </div>
                <% } else { %>
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: var(--primary); color: white;">
                                <th style="padding: 20px; text-align: left;">#</th>
                                <th style="padding: 20px; text-align: left;">Paper Title</th>
                                <th style="padding: 20px; text-align: left;">Author(s)</th>
                                <th style="padding: 20px; text-align: left;">Volume/Issue</th>
                                <th style="padding: 20px; text-align: center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% articles.forEach((art, index) => { %>
                                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.3s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
                                    <td style="padding: 20px; font-weight: 700; color: var(--primary);"><%= index + 1 %></td>
                                    <td style="padding: 20px;"><strong style="color: var(--primary-dark); font-size: 1.1rem;"><%= art.title %></strong></td>
                                    <td style="padding: 20px; color: var(--text-muted); font-style: italic;"><%= art.authors %></td>
                                    <td style="padding: 20px;"><span style="background: #eff6ff; color: #3b82f6; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Vol <%= art.volume_no %>, Issue <%= art.issue_no %></span></td>
                                    <td style="padding: 20px; text-align: center; white-space: nowrap;">
                                        <button class="btn view-abstract-trigger" 
                                                data-title="<%= art.title %>" 
                                                data-authors="<%= art.authors %>"
                                                data-abstract="<%= art.abstract %>"
                                                data-pdf="<%= art.file_path %>"
                                                style="padding: 8px 15px; font-size: 0.8rem; margin-right: 5px;">Read Abstract</button>
                                        <a href="/uploads/published/<%= art.file_path %>" target="_blank" class="btn btn-outline" style="padding: 8px 15px; font-size: 0.8rem; border-color: var(--border-color); color: var(--text-main);"><i class="fas fa-download"></i> Download</a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Premium Abstract Modal -->
    <div class="modal-overlay" id="abstractModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px); z-index: 10000; align-items: center; justify-content: center; padding: 20px;">
        <div class="modal-card" style="background: white; width: 100%; max-width: 750px; border-radius: 24px; padding: 45px; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); animation: modalFadeIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
            <button id="closeModal" style="position: absolute; top: 25px; right: 25px; background: none; border: none; color: #94a3b8; font-size: 2rem; cursor: pointer; transition: color 0.3s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#94a3b8'">&times;</button>
            
            <div style="margin-bottom: 30px;">
                <span style="background: #eff6ff; color: #3b82f6; padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Research Abstract</span>
                <h2 id="modalTitle" style="color: var(--primary-dark); margin-top: 15px; font-size: 1.8rem; line-height: 1.3; font-weight: 800; text-align: left;"></h2>
                <div id="modalAuthors" style="color: #64748b; font-style: italic; margin-top: 10px; font-size: 1rem; text-align: left;"></div>
            </div>

            <div style="background: #f8fafc; padding: 35px; border-radius: 16px; margin-bottom: 35px; border: 1px solid #e2e8f0; max-height: 400px; overflow-y: auto;">
                <div id="modalBody" style="line-height: 1.8; color: #334155; font-size: 1.1rem; text-align: justify; white-space: pre-line;"></div>
            </div>

            <div style="display: flex; gap: 15px;">
                <a href="#" id="modalDownloadBtn" class="btn" style="flex: 1; padding: 18px; border-radius: 12px; font-weight: 700; text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 10px;">
                    <i class="fas fa-download"></i> Download Full PDF
                </a>
                <button class="btn btn-outline" style="flex: 0.4; padding: 18px; border-radius: 12px; border: 1px solid #e2e8f0; font-weight: 600; color: var(--text-main);" onclick="document.getElementById('abstractModal').style.display='none'">Close</button>
            </div>
        </div>
    </div>

    <style>
        @keyframes modalFadeIn {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('abstractModal');
            const modalTitle = document.getElementById('modalTitle');
            const modalAuthors = document.getElementById('modalAuthors');
            const modalBody = document.getElementById('modalBody');
            const modalDownloadBtn = document.getElementById('modalDownloadBtn');
            const closeModal = document.getElementById('closeModal');

            document.querySelectorAll('.view-abstract-trigger').forEach(btn => {
                btn.addEventListener('click', () => {
                    modalTitle.textContent = btn.getAttribute('data-title');
                    modalAuthors.textContent = 'By ' + btn.getAttribute('data-authors');
                    modalBody.textContent = btn.getAttribute('data-abstract');
                    modalDownloadBtn.href = '/uploads/published/' + btn.getAttribute('data-pdf');
                    modal.style.display = 'flex';
                    document.body.style.overflow = 'hidden';
                });
            });

            closeModal.addEventListener('click', () => {
                modal.style.display = 'none';
                document.body.style.overflow = 'auto';
            });

            window.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.style.display = 'none';
                    document.body.style.overflow = 'auto';
                }
            });
        });
    </script>

<%- include('partials/footer') %>
