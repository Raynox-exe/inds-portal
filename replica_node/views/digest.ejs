<%- include('partials/header') %>

    <!-- Premium Hero Section -->
    <section class="hero digest-hero" style="min-height: 45vh; height: auto; display: flex; align-items: center; background: linear-gradient(rgba(0, 31, 63, 0.85), rgba(0, 31, 63, 0.85)), url('/assets/img/hero-gate.jpg') center/cover; padding: 100px 0; position: relative; text-align: center;">
        <div class="container" style="position: relative; z-index: 5;">
            <span class="section-tag" style="background: rgba(211, 140, 63, 0.2); color: #ffd19a; margin-bottom: 20px; display: inline-block;">Open Access Journal</span>
            <h1 style="color: #ffffff !important; font-size: clamp(2.5rem, 8vw, 4rem); margin-bottom: 20px; font-weight: 800; text-shadow: 0 4px 15px rgba(0,0,0,0.4);">Research Digest</h1>
            <p style="color: #ffffff !important; font-size: 1.25rem; max-width: 800px; margin: 0 auto; opacity: 1; font-weight: 500; line-height: 1.6;">Access the intellectual output of the Institute for Niger Delta Studies.</p>
        </div>
    </section>

    <!-- Digest List -->
    <section class="section">
        <div class="container">
            <div class="filter-section">
                <div class="filter-group">
                    <i class="fas fa-filter" style="color: var(--accent); font-size: 1.2rem;"></i>
                    <span style="font-weight: 700;">Browse Issues:</span>
                    <form action="/digest" method="GET" style="display: contents;">
                        <select name="volume_issue" onchange="const val = this.value.split('|'); if(val.length==2){ window.location='/digest?volume='+val[0]+'&issue='+val[1]; }" style="min-width: 250px;">
                            <option value="">All Volumes / Issues</option>
                            <% allJournals.forEach(j => { %>
                                <option value="<%= j.volume_no %>|<%= j.issue_no %>" <%= (selectedVol == j.volume_no && selectedIssue == j.issue_no) ? 'selected' : '' %>>
                                    Vol <%= j.volume_no %>, Issue <%= j.issue_no %> (<%= j.publication_year %>)
                                </option>
                            <% }); %>
                        </select>
                        <a href="/digest" id="clear-filters" class="btn btn-outline" style="padding: 10px 25px; font-size: 0.85rem; border-color: var(--primary); color: var(--primary);">Clear Filters</a>
                    </form>
                </div>
            </div>

            <div class="table-container" style="background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-md);">
                <% if (!articles || articles.length === 0) { %>
                    <div style="text-align: center; padding: 100px; opacity: 0.5;">
                        <i class="fas fa-folder-open" style="font-size: 4rem; margin-bottom: 20px;"></i>
                        <p>No published articles found for this selection.</p>
                    </div>
                <% } else { %>
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: var(--primary); color: white;">
                                <th style="padding: 20px; text-align: left;">#</th>
                                <th style="padding: 20px; text-align: left;">Paper Title</th>
                                <th style="padding: 20px; text-align: left;">Author(s)</th>
                                <th style="padding: 20px; text-align: left;">Volume/Issue</th>
                                <th style="padding: 20px; text-align: center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% articles.forEach((art, index) => { %>
                                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.3s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
                                    <td data-label="#" style="padding: 20px; font-weight: 700; color: var(--primary);"><%= index + 1 %></td>
                                    <td data-label="Paper Title" style="padding: 20px;"><strong style="color: var(--primary-dark); font-size: 1.1rem;"><%= art.title %></strong></td>
                                    <td data-label="Author(s)" style="padding: 20px; color: var(--text-muted); font-style: italic;"><%= art.authors %></td>
                                    <td data-label="Volume/Issue" style="padding: 20px;"><span style="background: #eff6ff; color: #3b82f6; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Vol <%= art.volume_no %>, Issue <%= art.issue_no %></span></td>
                                    <td data-label="Action" style="padding: 20px; text-align: center;">
                                        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                                            <button class="btn view-abstract-trigger" 
                                                    data-title="<%= art.title %>" 
                                                    data-authors="<%= art.authors %>"
                                                    data-abstract="<%= art.abstract %>"
                                                    data-pdf="<%= art.file_path %>"
                                                    data-download-enabled="<%= art.download_enabled %>"
                                                    style="padding: 10px 20px; font-size: 0.85rem; min-width: 140px; border-radius: 8px;">Read Abstract</button>
                                            
                                            <% if (art.download_enabled) { %>
                                                <a href="/uploads/published/<%= art.file_path %>" target="_blank" class="btn btn-outline" style="padding: 10px 20px; font-size: 0.85rem; border-color: var(--border-color); color: var(--text-main); min-width: 140px; border-radius: 8px;"><i class="fas fa-download"></i> Download</a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
