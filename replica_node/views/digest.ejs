<%- include('partials/header') %>

    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Research Digest</h1>
            <p>Access the intellectual output of the Institute for Niger Delta Studies.</p>
        </div>
    </section>

    <!-- Digest List -->
    <section class="section">
        <div class="container">
            <div class="volume-selector" style="margin-bottom: 40px; background: var(--bg-soft); padding: 25px; border-radius: 15px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 20px;">
                <i class="fas fa-filter" style="color: var(--accent); font-size: 1.2rem;"></i>
                <form action="/digest" method="GET" style="display: flex; gap: 15px; flex-grow: 1;">
                    <span style="font-weight: 700; color: var(--primary); align-self: center;">Browse Issues:</span>
                    <select name="volume_issue" onchange="const val = this.value.split('|'); if(val.length==2){ window.location='/digest?volume='+val[0]+'&issue='+val[1]; }" style="padding: 12px 20px; border-radius: 10px; border: 1px solid var(--border-color); background: white; font-weight: 500; outline: none; min-width: 250px;">
                        <option value="">All Volumes / Issues</option>
                        <% allJournals.forEach(j => { %>
                            <option value="<%= j.volume_no %>|<%= j.issue_no %>" <%= (selectedVol == j.volume_no && selectedIssue == j.issue_no) ? 'selected' : '' %>>
                                Vol <%= j.volume_no %>, Issue <%= j.issue_no %> (<%= j.publication_year %>)
                            </option>
                        <% }); %>
                    </select>
                    <a href="/digest" class="btn btn-outline" style="padding: 10px 25px; font-size: 0.85rem; border-color: var(--primary); color: var(--primary);">Clear Filters</a>
                </form>
            </div>

            <div class="table-container" style="background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-md);">
                <% if (!articles || articles.length === 0) { %>
                    <div style="text-align: center; padding: 100px; opacity: 0.5;">
                        <i class="fas fa-folder-open" style="font-size: 4rem; margin-bottom: 20px;"></i>
                        <p>No published articles found for this selection.</p>
                    </div>
                <% } else { %>
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: var(--primary); color: white;">
                                <th style="padding: 20px; text-align: left;">#</th>
                                <th style="padding: 20px; text-align: left;">Paper Title</th>
                                <th style="padding: 20px; text-align: left;">Author(s)</th>
                                <th style="padding: 20px; text-align: left;">Volume/Issue</th>
                                <th style="padding: 20px; text-align: center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% articles.forEach((art, index) => { %>
                                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.3s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
                                    <td style="padding: 20px; font-weight: 700; color: var(--primary);"><%= index + 1 %></td>
                                    <td style="padding: 20px;"><strong style="color: var(--primary-dark); font-size: 1.1rem;"><%= art.title %></strong></td>
                                    <td style="padding: 20px; color: var(--text-muted); font-style: italic;"><%= art.authors %></td>
                                    <td style="padding: 20px;"><span style="background: #eff6ff; color: #3b82f6; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">Vol <%= art.volume_no %>, Issue <%= art.issue_no %></span></td>
                                    <td style="padding: 20px; text-align: center;">
                                        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                                            <button class="btn view-abstract-trigger" 
                                                    data-title="<%= art.title %>" 
                                                    data-authors="<%= art.authors %>"
                                                    data-abstract="<%= art.abstract %>"
                                                    data-pdf="<%= art.file_path %>"
                                                    data-download-enabled="<%= art.download_enabled %>"
                                                    style="padding: 10px 20px; font-size: 0.85rem; min-width: 140px; border-radius: 8px;">Read Abstract</button>
                                            
                                            <% if (art.download_enabled) { %>
                                                <a href="/uploads/published/<%= art.file_path %>" target="_blank" class="btn btn-outline" style="padding: 10px 20px; font-size: 0.85rem; border-color: var(--border-color); color: var(--text-main); min-width: 140px; border-radius: 8px;"><i class="fas fa-download"></i> Download</a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
